{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/accelerator/layout,_N_T_/accelerator/page,_N_T_/accelerator"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
