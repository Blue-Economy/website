modules = ["nodejs-20", "ruby-3.2"]
[agent]
expertMode = true

[[ports]]
localPort = 5000
externalPort = 80

[nix]
packages = ["psmisc"]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
publicDir = "_site"
run = ["npm", "run", "start"]
